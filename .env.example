# ── Strava OAuth ─────────────────────────────────────────────────
# Create an app at https://www.strava.com/settings/api
#
# VITE_ prefix makes the client ID available to the browser AND to serverless
# functions. The secret must never have the VITE_ prefix.
VITE_STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret

# Must exactly match the "Authorization Callback Domain" set in your Strava app
# and the redirect_uri used in /api/auth/strava/auth.js.
# Local dev:  http://localhost:5173/api/auth/strava/callback
# Production: https://your-app.vercel.app/api/auth/strava/callback
STRAVA_REDIRECT_URI=http://localhost:5173/api/auth/strava/callback

# Arbitrary secret you choose — must match what you pass to Strava when
# registering the webhook subscription (see curl command in webhook/strava.js).
STRAVA_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# ── Supabase ─────────────────────────────────────────────────────
# VITE_ prefix exposes these to the browser AND makes them available to
# serverless functions. Find in Supabase → Settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # bypasses RLS — keep secret, no VITE_ prefix

# ── Supabase schema ───────────────────────────────────────────────
# Run these in the Supabase SQL editor.
#
# 1. Strava tokens — one row per runner slot (r1–r6).
#    strava_id is unique: one Strava account can't occupy two runner slots.
#
# create table strava_tokens (
#   runner_id     text   primary key,          -- "r1" … "r6"
#   strava_id     bigint unique not null,       -- Strava athlete ID
#   name          text,                         -- "First Last"
#   profile_pic   text,                         -- Strava profile photo URL
#   access_token  text   not null,
#   refresh_token text   not null,
#   expires_at    bigint not null,              -- Unix seconds
#   updated_at    timestamptz default now()
# );
#
# 2. Webhook events — activity:create events queued for processing.
#    A cron job or Supabase trigger reads rows with status='pending'.
#
# create table webhook_events (
#   id          bigint generated always as identity primary key,
#   runner_id   text   not null references strava_tokens(runner_id),
#   strava_id   bigint not null,
#   activity_id bigint not null,
#   event_time  bigint not null,               -- Unix seconds from Strava
#   status      text   not null default 'pending', -- pending | done | error
#   created_at  timestamptz default now()
# );
#
# 3. Webhook logs — optional, for dashboard visibility during testing.
#
# create table webhook_logs (
#   id      bigint generated always as identity primary key,
#   level   text,
#   message text,
#   meta    jsonb,
#   ts      timestamptz
# );
